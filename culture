            transform: translateY(-2px);
            box-shadow: 0 4px 20px var(--color-shadow);
            border-color: var(--color-secondary);
        }
        .tradition-item .emoji {
            font-size: 2rem;
            flex-shrink: 0;
        }
        .tradition-item .info h4 {
            font-weight: 600;
            font-size: 1rem;
        }
        .tradition-item .info p {
            font-size: 0.85rem;
            color: var(--color-text-muted);
            margin: 0;
        }

