                    { emoji: '🕯️', title: 'Deepavali', desc: 'Festival of lights celebrated with lamps and prayers.' },
                    { emoji: '🌾', title: 'Nawakh', desc: 'Harvest festival celebrating the new rice crop.' }
                ],
                festivals: [
                    { icon: '🕊️', name: 'Vivah Panchami', desc: 'Celebration of Rama-Sita marriage at Janakpur.' },
                    { icon: '🌅', name: 'Chhath Puja', desc: 'Sun worship with offerings at riverbanks.' },
                    { icon: '🎨', name: 'Madhubani Utsav', desc: 'Art festival showcasing Mithila\'s painting tradition.' },
                    { icon: '🎭', name: 'Sama-Chakeva', desc: 'A vibrant festival of sibling love and folk dance.' },
                    { icon: '🌸', name: 'Phaguwa (Holi)', desc: 'Colourful spring festival with Maithili songs.' },
                    { icon: '🕯️', name: 'Deepavali', desc: 'Festival of lights with traditional lamps.' }
                ]
            };

            // ---------- RENDER FUNCTIONS ----------
            function renderTraditions() {
                const container = document.getElementById('traditionsGrid');
                if (!container) return;
                let html = '';
                DATA.traditions.forEach(t => {
                    html += `
                        <div class="tradition-item">
                            <span class="emoji">${t.emoji}</span>
                            <div class="info">
                                <h4>${t.title}</h4>
                                <p>${t.desc}</p>
                            </div>
                        </div>
                    `;
                });
                container.innerHTML = html;
            }

            function renderFestivals() {
                const container = document.getElementById('festivalGrid');
                if (!container) return;
                let html = '';
                DATA.festivals.forEach(f => {
                    html += `
                        <div class="festival-card">
                            <span class="icon">${f.icon}</span>
                            <h4>${f.name}</h4>
                            <p>${f.desc}</p>
                        </div>
                    `;
                });
                container.innerHTML = html;
            }

            // ---------- BACK TO TOP ----------
            function initBackToTop() {
                const btn = document.getElementById('backToTop');
                if (!btn) return;
                window.addEventListener('scroll', function() {
                    if (window.scrollY > 600) {
                        btn.classList.add('visible');
                    } else {
                        btn.classList.remove('visible');
                    }
                });
                btn.addEventListener('click', function() {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            }

            // ---------- MOBILE NAV ----------
            function initMobileNav() {
                const toggle = document.getElementById('navToggle');
                const nav = document.getElementById('primaryNav');
                if (!toggle || !nav) return;
                toggle.addEventListener('click', function() {
                    const isOpen = nav.classList.toggle('open');
                    toggle.classList.toggle('active');
                    toggle.setAttribute('aria-expanded', isOpen);
                });
                document.addEventListener('click', function(e) {
                    if (!nav.contains(e.target) && !toggle.contains(e.target)) {
                        nav.classList.remove('open');
                        toggle.classList.remove('active');
                        toggle.setAttribute('aria-expanded', 'false');
                    }
                });
                const megaTriggers = nav.querySelectorAll('.mega-menu > a');
                megaTriggers.forEach(trigger => {
                    trigger.addEventListener('click', function(e) {
                        if (window.innerWidth <= 768) {
                            e.preventDefault();
                            const dropdown = this.nextElementSibling;
                            if (dropdown) {
                                dropdown.classList.toggle('open');
                            }
                        }
                    });
                });
            }

            // ---------- DARK MODE ----------
            function initDarkMode() {
                const toggle = document.getElementById('darkModeToggle');
                if (!toggle) return;
                const stored = localStorage.getItem('mithila-dark-mode');
                if (stored === 'true') {
                    document.documentElement.style.colorScheme = 'dark';
                }
                toggle.addEventListener('click', function() {
                    const isDark = document.documentElement.style.colorScheme === 'dark';
                    document.documentElement.style.colorScheme = isDark ? 'light' : 'dark';
                    localStorage.setItem('mithila-dark-mode', !isDark);
                });
            }

            // ---------- HEADER SCROLL ----------
            function initHeaderScroll() {
                const header = document.querySelector('.site-header');
                if (!header) return;
                window.addEventListener('scroll', function() {
                    if (window.scrollY > 20) {
                        header.classList.add('scrolled');
                    } else {
                        header.classList.remove('scrolled');
                    }
                });
            }

            // ---------- INIT ----------
            function init() {
                renderTraditions();
                renderFestivals();
                initBackToTop();
                initMobileNav();
                initDarkMode();
                initHeaderScroll();
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', init);
            } else {
                init();
            }

        })();
    </script>

</body>
</html>
