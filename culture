            font-size: 2.8rem;
            display: block;
            margin-bottom: var(--space-sm);
        }
        .festival-card h4 {
            font-weight: 600;
            font-size: 1.05rem;
        }
        .festival-card p {
            font-size: 0.9rem;
            color: var(--color-text-muted);
            margin-top: var(--space-xs);
        }

        /* ============================================================
               FOOTER (inherited)
               ============================================================ */
        .site-footer {
            background: var(--color-accent);
            color: rgba(255, 255, 255, 0.7);
            padding: var(--space-2xl) 0 var(--space-lg);
        }
        .site-footer .grid {
            gap: var(--space-xl);
        }
        .site-footer h4 {
            color: #fff;
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: var(--space-md);
