        }
        a:hover,
        a:focus-visible {
            color: var(--color-primary-dark);
        }
        button {
            cursor: pointer;
            font-family: inherit;
            font-size: inherit;
            border: none;
            background: none;
            color: inherit;
        }
        input,
        textarea,
        select {
            font-family: inherit;
            font-size: inherit;
            color: inherit;
            border: none;
            outline: none;
            background: none;
        }
        ul,
