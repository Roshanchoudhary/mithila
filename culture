            list-style: none;
        }

        /* ---------- UTILITY (inherited) ---------- */
        .container {
            max-width: var(--container-max);
            margin: 0 auto;
            padding: 0 var(--container-pad);
        }
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            border: 0;
        }
        .section-pad {
